<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zadanie1podstawowekontrolki.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label Style="{StaticResource Headline}" Text="Skontaktuj się z nami"/>

            <Entry Placeholder="Imię" x:Name="nameEntry" />
            <Entry  Placeholder="Nazwisko" x:Name="secondEntry"/>
            <Entry Placeholder="Adres E-mail" Keyboard="Email" x:Name="mailEntry"/>
            <Entry Placeholder="Temat:" x:Name="titleEntry"/>
            <Editor Placeholder="Napisz tu swoją wiadomość..." x:Name="messageEditor" HeightRequest="150"/>

            <Button Text="Wyślij" Clicked="wyswietlAlert"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
